PORT=3000
APP_MODE=manual
META_WEBHOOK_ENABLED=false
WEBHOOK_VERIFY_TOKEN=change-me
META_APP_SECRET=change-me
ENABLE_SIGNATURE_VALIDATION=true

INSTAGRAM_ACCESS_TOKEN=change-me
INSTAGRAM_IG_USER_ID=change-me
INSTAGRAM_API_VERSION=v23.0

AI_PROVIDER=openai
AI_REQUEST_TIMEOUT_MS=20000
LOG_LEVEL=info
STORAGE_PATH=./data/storage.sqlite
CONVERSATION_RETENTION_DAYS=30

OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

MAX_CONVERSATION_MESSAGES=30
MAX_PROCESSED_MESSAGES=5000
